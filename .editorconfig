# .editorconfig
# vim:set ft=ini
#
# top-most EditorConfig file
# EditorConfig is: https://EditorConfig.org

root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = false
insert_final_newline = false

[*.sh]
indent_size = 4

[*.yaml]
insert_final_newline = true

[*.{c,cpp}]
indent_size = 4

# Tab indentation (no size specified)
[Makefile]
indent_style = tab
